APP_NAME=tts-service
APP_ENV=prod
LOG_LEVEL=INFO
PORT=8000
WORKERS=2

INTERNAL_API_KEY=replace_with_strong_secret

ALIYUN_API_KEY=your_aliyun_api_key
ALIYUN_TTS_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
ALIYUN_MODEL=cosyvoice-v1
ALIYUN_TIMEOUT_SECONDS=20

ENABLE_TENCENT_FALLBACK=true
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-guangzhou
TENCENT_SESSION_ID_PREFIX=tts_sess
TENCENT_MODEL_TYPE=1
TENCENT_VOLUME=0
TENCENT_SPEED=0
TENCENT_PROJECT_ID=0
TENCENT_PRIMARY_VOICE_TYPE=101001

REDIS_URL=redis://redis:6379/0
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=your_bucket_name
OSS_PUBLIC_BASE_URL=https://your_bucket_name.oss-cn-hangzhou.aliyuncs.com

CACHE_MAX_ITEMS=5000
CACHE_TTL_SECONDS=86400
